# Environment Variables Configuration
# Copy this file to a new file named '.env' in this directory and populate the actual database URL.

# When DATABASE_URL is set, the app connects to PostgreSQL (e.g., Supabase, Neon).
# If left blank or deleted, the app defaults to the local SQLite database file.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.nybiafznfvqwkibtshxg.supabase.co:5432/postgres

# Port for the Node server (defaults to 5000)
PORT=5000
